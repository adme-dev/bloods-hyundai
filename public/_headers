# Netlify _headers file
# Ensures proper MIME types and caching for all static assets

# All Nuxt assets - immutable with long cache
/_nuxt/*
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff

# CSS files - ensure correct MIME type
/_nuxt/*.css
  Content-Type: text/css; charset=utf-8
  Cache-Control: public, max-age=31536000, immutable

# JavaScript files - ensure correct MIME type  
/_nuxt/*.js
  Content-Type: application/javascript; charset=utf-8
  Cache-Control: public, max-age=31536000, immutable

# JSON files - API responses and config
/_nuxt/*.json
  Content-Type: application/json; charset=utf-8
  Cache-Control: public, max-age=3600, must-revalidate

# Font files
/_nuxt/*.woff
  Content-Type: font/woff
  Cache-Control: public, max-age=31536000, immutable

/_nuxt/*.woff2
  Content-Type: font/woff2
  Cache-Control: public, max-age=31536000, immutable

# Images in assets
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# LLM discovery file
/llms.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=3600, must-revalidate

# HTML pages - no cache to always get latest
/*.html
  Cache-Control: no-cache, no-store, must-revalidate

# Root index - short CDN cache, browser revalidates
/
  Cache-Control: public, max-age=0, must-revalidate
  Netlify-CDN-Cache-Control: public, max-age=300, stale-while-revalidate=3600
  CDN-Cache-Control: public, max-age=300, stale-while-revalidate=3600
