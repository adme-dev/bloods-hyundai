# Cloudflare R2 Storage Configuration
# =====================================
# Used for multi-tenant file storage (logos, images, documents)
#
# Setup Instructions:
# 1. Go to Cloudflare Dashboard > R2
# 2. Create a bucket (e.g., "dealer-assets")
# 3. Go to "Manage R2 API Tokens" > Create API Token
# 4. Select "Object Read & Write" permissions
# 5. Copy the credentials below
#
# For public access:
# - Enable "Public Access" on your bucket, OR
# - Set up a custom domain for your R2 bucket
# - Set R2_PUBLIC_URL to your public URL

# Your Cloudflare Account ID (found in dashboard URL or sidebar)
CLOUDFLARE_ACCOUNT_ID=your_account_id_here

# R2 API Token credentials (from step 3-5 above)
R2_ACCESS_KEY_ID=your_access_key_id_here
R2_SECRET_ACCESS_KEY=your_secret_access_key_here

# Bucket name (create this in Cloudflare R2 dashboard)
R2_BUCKET_NAME=dealer-assets

# Public URL for accessing files
# Option 1: R2.dev URL (enable in bucket settings)
# R2_PUBLIC_URL=https://pub-xxxxxxxxxxxx.r2.dev
#
# Option 2: Custom domain (configure in Cloudflare DNS + R2)
# R2_PUBLIC_URL=https://assets.yourdomain.com
R2_PUBLIC_URL=
